---
import "@/styles/css/global.css"
import Header from "@/components/layout/Header.astro"
import Footer from "@/components/layout/Footer.astro"
import FloatingWidgets from "@/components/layout/FloatingWidgets.astro"
import SEO from "@/components/seo/SEO.astro"
import { getHomeConfig } from "@/features/home/services"

interface Props {
  title?: string
  description?: string
  image?: string
  type?: "website" | "article"
  canonicalURL?: string
  noindex?: boolean
  pubDate?: Date | string
  updatedDate?: Date | string
  author?: string
  tags?: string[]
}

const {
  title,
  description,
  image,
  type,
  canonicalURL,
  noindex,
  pubDate,
  updatedDate,
  author,
  tags,
} = Astro.props

const homeConfig = await getHomeConfig()
const siteConfig = homeConfig?.site || null
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Nhúng Component SEO chuyên nghiệp -->
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      canonicalURL={canonicalURL}
      noindex={noindex}
      pubDate={pubDate}
      updatedDate={updatedDate}
      author={author}
      tags={tags}
    />

    <!-- Link XML Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Link RSS Feed -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="LuxiArc RSS Feed"
      href="/rss.xml"
    />
  </head>
  <body class="min-h-screen">
    <Header siteConfig={siteConfig} />
    <main>
      <slot />
    </main>
    <Footer siteConfig={siteConfig} />

    <!-- Widget nổi tròn cố định góc phải -->
    <FloatingWidgets />
  </body>
</html>
