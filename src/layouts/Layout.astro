---
import "@/styles/global.css";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";

interface Props {
  title?: string;
  fullWidth?: boolean;
  showHeader?: boolean;
  showFooter?: boolean;
}

const { title = "LuxiArc", fullWidth = false, showHeader = true, showFooter = true } = Astro.props;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    {showHeader && <Header />}

    <main class:list={fullWidth ? "mx-auto w-full max-w-none px-0 py-0" : "mx-auto max-w-5xl px-4 py-12"}>
      <slot />
    </main>

    {showFooter && <Footer />}
  </body>
</html>
