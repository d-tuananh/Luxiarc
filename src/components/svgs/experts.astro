---
import type { HTMLAttributes } from "astro/types"
import { cn } from "@/utils/cn"

type Props = HTMLAttributes<"svg">
const { class: className, ...props } = Astro.props
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="currentColor"
  class={cn("size-full", className)}
  {...props}
>
  <path
    d="M12 12c2.2 0 4-1.8 4-4s-1.8-4-4-4-4 1.8-4 4 1.8 4 4 4zm0 2c-2.7 0-8 1.3-8 4v2h16v-2c0-2.7-5.3-4-8-4z"
  ></path>
  <path
    d="M11.5 2h1v1h-1zM7.5 5.5c0-2.5 2-4.5 4.5-4.5s4.5 2 4.5 4.5h-9z"
    opacity="0.9"></path>
</svg>
