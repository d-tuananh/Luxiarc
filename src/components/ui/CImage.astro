---
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"
import type { HTMLAttributes } from "astro/types"

interface Props extends Omit<
  HTMLAttributes<"img">,
  "src" | "width" | "height"
> {
  src: string | ImageMetadata | null | undefined // Can be a string path or imported ImageMetadata object
  alt: string
  fallback?: string
  width?: string | number
  height?: string | number
}

const {
  src,
  alt,
  class: className,
  fallback = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'%3E%3C/svg%3E",
  width = "100%",
  height = "100%",
  ...props
} = Astro.props

const isAssetObject = typeof src === "object" && src !== null
const finalSrc = src || fallback

// Parse width và height thành kiểu number | undefined thích hợp cho Astro Image
const parsedWidth = width && !isNaN(Number(width)) ? Number(width) : undefined
const parsedHeight =
  height && !isNaN(Number(height)) ? Number(height) : undefined
---

{
  isAssetObject ? (
    <Image
      src={finalSrc}
      alt={alt}
      class={className}
      width={parsedWidth}
      height={parsedHeight}
      {...props}
    />
  ) : (
    <img
      src={finalSrc}
      alt={alt}
      class={className}
      width={width}
      height={height}
      loading="lazy"
      {...props}
    />
  )
}
