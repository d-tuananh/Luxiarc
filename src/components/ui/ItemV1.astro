---
import CImage from "./CImage.astro"
import CLink from "./CLink.astro"

interface Props {
  title: string
  image: string
  href: string
}

const { title, image, href } = Astro.props
---

<div>
  <CLink href={href} title={title} class="c-img pt-[59%] block mb-3">
    <CImage src={image} alt={title} />
  </CLink>
  <CLink
    href={href}
    title={title}
    class="line-clamp-1 text-primary text-[1.25rem] lg:text-[1.5rem] font-semibold hover:text-secondary text-center"
  >
    {title}
  </CLink>
</div>
