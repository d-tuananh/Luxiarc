---
import type { HTMLAttributes } from "astro/types"

interface Props extends HTMLAttributes<"a"> {
  href: string
  activeClass?: string
  prefetch?: boolean | "tap" | "hover" | "viewport" | "none"
}

const {
  href,
  class: className,
  activeClass = "active",
  prefetch = "hover",
  ...props
} = Astro.props

// Chuẩn hóa path để so sánh active state
const currentPath = Astro.url.pathname.replace(/\/$/, "")
const linkPath = href.replace(/\/$/, "")

// Link active nếu trùng hoàn toàn hoặc là thư mục con (ngoại trừ trang chủ)
const isActive = 
  currentPath === linkPath || 
  (linkPath !== "" && linkPath !== "/" && currentPath.startsWith(linkPath + "/"))

// Tự động phát hiện link ngoài (external link) để thêm target và rel an toàn
const isExternal = href.startsWith("http://") || href.startsWith("https://") || href.startsWith("//")

const target = isExternal ? "_blank" : undefined
const rel = isExternal ? "noopener noreferrer" : undefined
---

<a
  href={href}
  class:list={[className, { [activeClass]: isActive }]}
  target={target}
  rel={rel}
  data-astro-prefetch={!isExternal ? prefetch : undefined}
  aria-current={isActive ? "page" : undefined}
  {...props}
>
  <slot />
</a>
