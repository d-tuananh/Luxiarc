---
const trustBg = "https://www.figma.com/api/mcp/asset/69ae6668-419c-4fee-9ea9-56046ec40d15";
const trustSide1 = "https://www.figma.com/api/mcp/asset/6d6364e0-46aa-436a-a6a4-f48255cd38ce";
const trustSide2 = "https://www.figma.com/api/mcp/asset/0953035a-30fa-41c3-9f2b-48f4f1d5de79";
---

<section class="relative overflow-hidden">
  <div class="relative h-[384px] w-full overflow-hidden bg-brand-900">
    <img src={trustBg} alt="" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-[rgba(29,47,58,0.6)]"></div>
    <img src={trustSide1} alt="" class="absolute -left-[349px] top-0 h-[384px] w-[639px] object-cover" />
    <img src={trustSide2} alt="" class="absolute -right-[350px] top-0 h-[425px] w-[708px] object-cover" />

    <div class="absolute inset-0 flex items-center justify-center px-4 text-center text-white">
      <div class="max-w-[849px]">
        <div class="inline-flex rounded-full bg-white/20 px-8 py-3 backdrop-blur-[4px]">
          <p class="text-[40px] font-bold uppercase leading-none">Trai nghiem ban co the tin cay</p>
        </div>
        <p class="mt-6 text-[16px] leading-7 text-white/90">Lorem ipsum dolor sit amet consectetur. Volutpat tellus tortor tempor sit viverra. Sed mauris et ultrices hendrerit. Elit penatibus nunc libero adipiscing enim ut morbi eu nunc.</p>
      </div>
    </div>
  </div>
</section>
