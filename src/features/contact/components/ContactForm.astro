---
interface Props {
  buttonText?: string
}

const { buttonText = "Gửi thông tin" } = Astro.props
---

<form
  id="contact-form"
  class="bg-white w-full space-y-3.5 p-6 shadow-[3px_3px_10px_0_rgba(0,0,0,0.12)]"
>
  <!-- Họ và tên -->
  <input
    type="text"
    id="fullname"
    name="fullname"
    required
    placeholder="Họ và tên *"
    class="block w-full py-2 border-b border-[#9F9F9F] outline-none"
  />

  <!-- Số điện thoại -->
  <input
    type="tel"
    id="phone"
    name="phone"
    required
    placeholder="Số điện thoại *"
    class="block w-full py-2 border-b border-[#9F9F9F] outline-none"
  />

  <!-- Email -->
  <input
    type="email"
    id="email"
    name="email"
    required
    placeholder="Email *"
    class="block w-full py-2 border-b border-[#9F9F9F] outline-none"
  />

  <!-- Dịch vụ -->
  <select
    id="service"
    name="service"
    class="block w-full py-2 border-b border-[#9F9F9F] outline-none"
  >
    <option value="" disabled selected>Dịch vụ</option>
    <option value="thiet-ke">Thiết kế nội thất</option>
    <option value="thi-cong">Thi công trọn gói</option>
    <option value="tu-van">Tư vấn pháp lý & xây dựng</option>
  </select>

  <!-- Nội dung -->
  <textarea
    id="message"
    name="message"
    rows="3"
    placeholder="Nội dung"
    class="block w-full py-2 border-b border-[#9F9F9F] resize-none outline-none"
  ></textarea>

  <!-- Nút submit -->
  <button type="submit" class="btn"> {buttonText} </button>
</form>

<script>
  import Toastify from "toastify-js"
  import "toastify-js/src/toastify.css"
  import { api } from "@/utils/api"

  // Hiển thị thông báo Toastify
  const showNotify = (code: number, message: string) => {
    if (!message) return
    document.querySelectorAll(".toastify").forEach((el) => el.remove())
    Toastify({
      text: message,
      close: false,
      duration: 3000,
      gravity: "top",
      position: "right",
      style: {
        background: code === 200 ? "#06d6a0" : "#ef476f",
        borderRadius: "4px",
        fontSize: "15px",
        padding: "12px 20px",
        boxShadow: "0 4px 12px rgba(0, 0, 0, 0.15)",
      },
    }).showToast()
  }

  // Tính toán kích thước padding và content của element
  const getInnerDimensions = (element: HTMLElement) => {
    const computedStyle = window.getComputedStyle(element)
    let width = element.clientWidth
    let height = element.clientHeight
    height -=
      parseFloat(computedStyle.paddingTop) +
      parseFloat(computedStyle.paddingBottom)
    width -=
      parseFloat(computedStyle.paddingLeft) +
      parseFloat(computedStyle.paddingRight)
    return { height, width }
  }

  // Vô hiệu hóa nút và hiển thị spinner loading khớp kích thước
  const disableButton = (button: HTMLButtonElement) => {
    const dimensions = getInnerDimensions(button)
    const loadingSvg = `
      <span style="display: flex; text-align: center; width: ${dimensions.width}px; height: ${dimensions.height}px; justify-content: center; align-items: center; margin: auto;">
        <svg xmlns="http://www.w3.org/2000/svg" style="margin: auto; background: none; display: block; shape-rendering: auto;" width="32px" height="32px" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid">
          <circle cx="50" cy="50" fill="none" stroke="currentColor" stroke-width="7" r="44" stroke-dasharray="207.34511513692632 71.1150383zc897544">
            <animateTransform attributeName="transform" type="rotate" repeatCount="indefinite" dur="0.6s" values="0 50 50;360 50 50" keyTimes="0;1"></animateTransform>
          </circle>
        </svg>
      </span>`
    button.setAttribute("data-old-html", button.innerHTML)
    button.innerHTML = loadingSvg
    button.disabled = true
    button.style.pointerEvents = "none"
  }

  // Khôi phục nút về trạng thái ban đầu
  const enableButton = (button: HTMLButtonElement) => {
    const oldHtml = button.getAttribute("data-old-html")
    if (oldHtml !== null) {
      button.innerHTML = oldHtml
      button.removeAttribute("data-old-html")
    }
    button.disabled = false
    button.style.pointerEvents = "all"
  }

  // Đăng ký sự kiện submit form
  const form = document.querySelector("#contact-form") as HTMLFormElement
  if (form) {
    // Để nguyên để trình duyệt hiển thị bong bóng thông báo lỗi mặc định của HTML5

    form.addEventListener("submit", async (e) => {
      e.preventDefault()

      const fullnameInput = form.querySelector("#fullname") as HTMLInputElement
      const phoneInput = form.querySelector("#phone") as HTMLInputElement
      const emailInput = form.querySelector("#email") as HTMLInputElement
      const serviceSelect = form.querySelector("#service") as HTMLSelectElement
      const messageTextarea = form.querySelector(
        "#message"
      ) as HTMLTextAreaElement
      const submitButton = form.querySelector(
        'button[type="submit"]'
      ) as HTMLButtonElement

      // Xây dựng payload gửi lên API
      const payload = {
        name: fullnameInput.value.trim(),
        phone: phoneInput.value.trim(),
        email: emailInput.value.trim(),
        service: serviceSelect.value,
        content: messageTextarea.value.trim(),
        source_page: window.location.href,
      }

      try {
        if (submitButton) disableButton(submitButton)

        const responseData = await api.post<{ message?: string }>(
          "contact-submissions",
          payload
        )

        // Hiện thông báo thành công qua Toastify
        showNotify(
          200,
          responseData?.message || "Gửi thông tin liên hệ thành công!"
        )
        form.reset()
      } catch (error: any) {
        console.error("Lỗi gửi form:", error)
        const errMsg =
          error instanceof Error
            ? error.message
            : "Đã xảy ra lỗi hệ thống. Vui lòng thử lại sau."
        showNotify(100, errMsg)
      } finally {
        if (submitButton) enableButton(submitButton)
      }
    })
  }
</script>
