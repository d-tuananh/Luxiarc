---
const buildingIcon = "https://www.figma.com/api/mcp/asset/9dfdcd1a-41ee-4353-a40b-4744ac604479";
const phoneIcon = "https://www.figma.com/api/mcp/asset/fe7fd795-4d35-4199-8a9d-dd2549923ed2";
const mailIcon = "https://www.figma.com/api/mcp/asset/bf6db4b4-b8f5-482c-be56-aec097257be0";
const arrowDownIcon = "https://www.figma.com/api/mcp/asset/b0607589-b77d-466c-9b56-bf191a612f2a";
const lineArt = "https://www.figma.com/api/mcp/asset/bb7541be-63fb-4c33-9e16-d19660fe0f9d";
const designIcon = "https://www.figma.com/api/mcp/asset/5e2fce04-ad1f-43fd-9b9e-c9798b14dbcd";
const vrIcon = "https://www.figma.com/api/mcp/asset/789f6449-834a-4a62-9f4a-780f4e30cd67";
const compareIcon = "https://www.figma.com/api/mcp/asset/183e5190-e7f5-4d53-8f63-eb21dce3785a";
const zaloIcon = "https://www.figma.com/api/mcp/asset/b25f0535-2f3d-4ca4-9c76-4397b5a7d4b0";
---

<section class="bg-[#eceeef] py-12 md:py-16">
  <div class="container-home relative">
    <div class="grid gap-10 xl:grid-cols-[minmax(0,1fr)_461px] xl:gap-12">
      <div class="relative overflow-hidden pt-2">
        <p class="text-[15px] font-semibold uppercase tracking-[0.24em] text-accent-500">Lien he</p>
        <h1 class="mt-4 max-w-[720px] text-[44px] font-semibold uppercase leading-[1.08] text-brand-900 md:text-[52px]">
          Liên hệ với chúng tôi để nhận thông tin
        </h1>

        <div class="mt-10 grid gap-5 sm:grid-cols-2 xl:max-w-[760px]">
          <article class="rounded-[18px] border border-white/70 bg-white px-5 py-5 shadow-[0_12px_30px_rgba(19,32,41,0.06)]">
            <div class="flex items-start gap-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-full border border-accent-500/40 bg-[#f7f3e5]">
                <img src={buildingIcon} alt="" class="h-7 w-7 object-contain" />
              </div>
              <div class="min-w-0">
                <p class="text-[17px] font-semibold uppercase text-brand-900">Van phong</p>
                <p class="mt-2 text-[15px] leading-7 text-text-700">So 183 Cau Giay, Thanh Xuan, Ha Noi</p>
              </div>
            </div>
          </article>

          <article class="rounded-[18px] border border-white/70 bg-white px-5 py-5 shadow-[0_12px_30px_rgba(19,32,41,0.06)]">
            <div class="flex items-start gap-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-full border border-accent-500/40 bg-[#f7f3e5]">
                <img src={phoneIcon} alt="" class="h-7 w-7 object-contain" />
              </div>
              <div class="min-w-0">
                <p class="text-[17px] font-semibold uppercase text-brand-900">Hotline</p>
                <p class="mt-2 text-[15px] leading-7 text-text-700">0989.84.6666</p>
                <p class="text-[15px] leading-7 text-text-700">Hotline tu van 24/7</p>
              </div>
            </div>
          </article>

          <article class="rounded-[18px] border border-white/70 bg-white px-5 py-5 shadow-[0_12px_30px_rgba(19,32,41,0.06)]">
            <div class="flex items-start gap-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-full border border-accent-500/40 bg-[#f7f3e5]">
                <img src={mailIcon} alt="" class="h-7 w-7 object-contain" />
              </div>
              <div class="min-w-0">
                <p class="text-[17px] font-semibold uppercase text-brand-900">Email</p>
                <p class="mt-2 text-[15px] leading-7 text-text-700">lienhe@luxiarc.vn</p>
                <p class="text-[15px] leading-7 text-text-700">Phan hoi trong 24 gio</p>
              </div>
            </div>
          </article>

          <article class="rounded-[18px] border border-white/70 bg-white px-5 py-5 shadow-[0_12px_30px_rgba(19,32,41,0.06)]">
            <div class="flex items-start gap-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-full border border-accent-500/40 bg-[#f7f3e5]">
                <img src={buildingIcon} alt="" class="h-7 w-7 object-contain" />
              </div>
              <div class="min-w-0">
                <p class="text-[17px] font-semibold uppercase text-brand-900">Gio lam viec</p>
                <p class="mt-2 text-[15px] leading-7 text-text-700">08:00 - 18:00, Thu 2 - Thu 7</p>
              </div>
            </div>
          </article>
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-4 text-[15px] text-text-700">
          <span class="inline-flex items-center gap-2 rounded-full border border-[#d7dbdf] bg-white px-4 py-2">
            <span class="h-2 w-2 rounded-full bg-accent-500"></span>
            Tu van du an
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-[#d7dbdf] bg-white px-4 py-2">
            <span class="h-2 w-2 rounded-full bg-brand-700"></span>
            Bao gia nhanh
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-[#d7dbdf] bg-white px-4 py-2">
            <span class="h-2 w-2 rounded-full bg-brand-900"></span>
            Ho tro ky thuat
          </span>
        </div>

        <div class="relative mt-12 hidden min-h-[220px] lg:block">
          <img src={lineArt} alt="" class="absolute left-0 top-0 h-[240px] w-[420px] object-contain opacity-35" />
        </div>
      </div>

      <div class="relative">
        <form class="relative z-10 rounded-[2px] bg-white p-6 shadow-[0_18px_45px_rgba(19,32,41,0.12)] md:p-8">
          <div class="grid gap-4">
            <label class="block">
              <span class="mb-2 block text-[15px] font-medium text-text-700">Ho va ten <span class="text-[#d13c3c]">*</span></span>
              <input type="text" placeholder="Nhap ho va ten" class="w-full border-b border-[#9f9f9f] bg-transparent px-0 py-3 text-[16px] text-text-900 outline-none placeholder:text-[#979797]" />
            </label>
            <label class="block">
              <span class="mb-2 block text-[15px] font-medium text-text-700">So dien thoai <span class="text-[#d13c3c]">*</span></span>
              <input type="tel" placeholder="Nhap so dien thoai" class="w-full border-b border-[#9f9f9f] bg-transparent px-0 py-3 text-[16px] text-text-900 outline-none placeholder:text-[#979797]" />
            </label>
            <label class="block">
              <span class="mb-2 block text-[15px] font-medium text-text-700">Email</span>
              <input type="email" placeholder="Nhap email" class="w-full border-b border-[#9f9f9f] bg-transparent px-0 py-3 text-[16px] text-text-900 outline-none placeholder:text-[#979797]" />
            </label>
            <label class="block">
              <span class="mb-2 block text-[15px] font-medium text-text-700">Dich vu</span>
              <div class="relative">
                <select class="w-full appearance-none border-b border-[#9f9f9f] bg-transparent px-0 py-3 text-[16px] text-[#979797] outline-none">
                  <option>Chon dich vu</option>
                  <option>Tu van thiet ke</option>
                  <option>Thi cong tron goi</option>
                  <option>Bao tri - nang cap</option>
                </select>
                <img src={arrowDownIcon} alt="" class="pointer-events-none absolute right-0 top-1/2 h-5 w-5 -translate-y-1/2" />
              </div>
            </label>
            <label class="block">
              <span class="mb-2 block text-[15px] font-medium text-text-700">Noi dung</span>
              <textarea rows="5" placeholder="Nhap noi dung can tu van" class="min-h-[132px] w-full resize-none border-b border-[#9f9f9f] bg-transparent px-0 py-3 text-[16px] text-text-900 outline-none placeholder:text-[#979797]"></textarea>
            </label>
          </div>

          <button type="submit" class="mt-6 inline-flex h-12 items-center justify-center bg-accent-500 px-6 text-[16px] font-semibold text-white transition-colors hover:bg-[#bda54d]">
            Gui thong tin
          </button>
        </form>

        <div class="absolute right-[-84px] top-6 hidden w-[64px] flex-col gap-[10px] xl:flex">
          <a href="/" class="relative h-[64px] rounded-[58px] border-[1.5px] border-white shadow-[0_0_5px_rgba(255,255,255,0.3)]">
            <div class="absolute inset-0 rounded-[58px] bg-[linear-gradient(270deg,rgba(255,255,255,0.8)_0%,rgba(152,152,152,0.8)_26.361%,rgba(242,242,242,0.8)_51.664%,rgba(221,221,221,0.8)_70.963%,rgba(135,135,135,0.8)_100%)] backdrop-blur-[3.5px]"></div>
            <img src={designIcon} alt="" class="absolute left-1/2 top-[8px] h-6 w-6 -translate-x-1/2" />
            <p class="absolute left-[12px] top-[42px] text-[8px] text-text-700">Tu thiet ke</p>
          </a>
          <a href="/" class="relative h-[64px] rounded-[58px] border-[1.5px] border-white shadow-[0_0_5px_rgba(255,255,255,0.3)]">
            <div class="absolute inset-0 rounded-[58px] bg-[linear-gradient(270deg,rgba(255,255,255,0.8)_0%,rgba(152,152,152,0.8)_26.361%,rgba(242,242,242,0.8)_51.664%,rgba(221,221,221,0.8)_70.963%,rgba(135,135,135,0.8)_100%)] backdrop-blur-[3.5px]"></div>
            <img src={vrIcon} alt="" class="absolute left-1/2 top-[8px] h-6 w-6 -translate-x-1/2" />
            <p class="absolute left-[16px] top-[42px] text-[8px] text-text-700">3D VR360</p>
          </a>
          <a href="/" class="relative h-[64px] rounded-[58px] border-[1.5px] border-white shadow-[0_0_5px_rgba(255,255,255,0.3)]">
            <div class="absolute inset-0 rounded-[58px] bg-[linear-gradient(270deg,rgba(255,255,255,0.8)_0%,rgba(152,152,152,0.8)_26.361%,rgba(242,242,242,0.8)_51.664%,rgba(221,221,221,0.8)_70.963%,rgba(135,135,135,0.8)_100%)] backdrop-blur-[3.5px]"></div>
            <img src={compareIcon} alt="" class="absolute left-1/2 top-[8px] h-6 w-6 -translate-x-1/2" />
            <p class="absolute left-[16px] top-[42px] text-[8px] text-text-700">So sanh</p>
          </a>
          <a href="/" class="relative h-[64px] rounded-[58px] border-[1.5px] border-white shadow-[0_0_5px_rgba(255,255,255,0.3)]">
            <div class="absolute inset-0 rounded-[58px] bg-[linear-gradient(270deg,rgba(255,255,255,0.8)_0%,rgba(152,152,152,0.8)_26.361%,rgba(242,242,242,0.8)_51.664%,rgba(221,221,221,0.8)_70.963%,rgba(135,135,135,0.8)_100%)] backdrop-blur-[3.5px]"></div>
            <img src={zaloIcon} alt="" class="absolute left-1/2 top-3 h-6 w-6 -translate-x-1/2" />
            <p class="absolute left-[10px] top-[42px] text-[8px] text-text-700">Lien he Zalo</p>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
