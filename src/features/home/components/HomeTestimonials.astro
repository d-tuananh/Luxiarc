---
// HomeTestimonials.astro - Khách hàng nói gì?
import HomeTestimonialCard from "./HomeTestimonialCard.astro"
import { getTestimonials, getHighlights } from "../services"

const testimonials = await getTestimonials()
const highlights = await getHighlights()

// Chia đôi danh sách testimonials cho 2 dòng Swiper
const half = Math.ceil(testimonials.length / 2)
const topReviews = testimonials.slice(0, half)
const bottomReviews = testimonials.slice(half)

// Lấy 2 highlight
const highlight1 = highlights[0] || { title: "Hài lòng", subtitle: "99%" }
const highlight2 = highlights[1] || { title: "Tinh tế & nhất quán" }
---

<section class="py-16 container">
  <h2 class="title-head mb-8 text-center">Khách hàng nói gì?</h2>

  <div class="grid grid-cols-1 lg:grid-cols-3">
    <div
      class="bg-[#EBECEE] p-8 lg:p-10 flex flex-col items-center justify-center min-h-60 lg:min-h-80 lg:order-1"
      style="clip-path: polygon(0 0, calc(100% - 40px) 0, 100% 40px, 100% 100%, 0 100%);"
    >
      <span class="text-primary font-bold text-[1.5rem] uppercase"> {highlight1.title} </span>
      <span class="text-stroke-dark mt-2"> {highlight1.subtitle} </span>
    </div>
    <div class="col-span-1 lg:col-span-2">
      <div class="swiper h-full swiper-testimonials-top overflow-hidden">
        <div class="swiper-wrapper divide-x divide-[#CACACA]">
          {
            topReviews.map((review) => (
              <div class="swiper-slide h-auto!">
                <HomeTestimonialCard
                  avatar={review.image || "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=80&h=80&q=80"}
                  name={review.title}
                  text={review.content}
                  class="border-t border-[#CACACA]"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3">
    <div
      class="bg-[#FAF5EC] p-8 lg:p-10 flex flex-col items-center justify-center min-h-60 lg:min-h-80"
      style="clip-path: polygon(40px 0, 100% 0, 100% 100%, 0 100%, 0 40px);"
    >
      <div
        class="text-center uppercase text-[1.5rem] lg:text-[2rem] font-bold text-[#DFC976]"
      >
        {highlight2.title}
      </div>
    </div>

    <div class="col-span-1 lg:col-span-2">
      <div class="swiper h-full swiper-testimonials-bottom overflow-hidden">
        <div class="swiper-wrapper divide-x divide-[#CACACA]">
          {
            bottomReviews.map((review) => (
              <div class="swiper-slide h-auto!">
                <HomeTestimonialCard
                  avatar={review.image || "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=80&h=80&q=80"}
                  name={review.title}
                  text={review.content}
                  class="border-t border-[#CACACA]"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper"
  import "swiper/css"

  var initTestimonialsSliders = function () {
    var topSlider = document.querySelector(
      ".swiper-testimonials-top"
    ) as HTMLElement
    if (topSlider) {
      new Swiper(topSlider, {
        slidesPerView: 1,
        spaceBetween: 0,
        loop: true,
        breakpoints: {
          640: {
            slidesPerView: 2,
          },
        },
      })
    }

    var bottomSlider = document.querySelector(
      ".swiper-testimonials-bottom"
    ) as HTMLElement
    if (bottomSlider) {
      new Swiper(bottomSlider, {
        slidesPerView: 1,
        spaceBetween: 0,
        loop: true,
        breakpoints: {
          640: {
            slidesPerView: 2,
          },
        },
      })
    }
  }

  // Khởi chạy khi DOM đã sẵn sàng
  document.addEventListener("DOMContentLoaded", initTestimonialsSliders)
  document.addEventListener("astro:page-load", initTestimonialsSliders)
</script>

<style>
  .text-stroke-dark {
    color: rgba(19, 32, 41, 0);
    text-align: center;
    -webkit-text-stroke-width: 1px;
    -webkit-text-stroke-color: var(--Main, #132029);
    font-family: "Hanken Grotesk";
    font-size: 104px;
    font-style: normal;
    font-weight: 900;
    line-height: 100%; /* 104px */
    text-transform: uppercase;
  }
</style>
