---
// HomeWhyChooseUs.astro - Tại sao chọn chúng tôi?
import { Design, Materials, Experts, Pricing } from "@/components/svgs/config"
import { getWhyChooseUsItems } from "../services"

const items = await getWhyChooseUsItems()

// Bản đồ ánh xạ Icon tương ứng với thứ tự của API trả về
const iconMap = [Design, Materials, Experts, Pricing]
---

<section class="py-8 container">
  <h2 class="title-head mb-8 text-center">Tại sao chọn chúng tôi?</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
    {
      items.map((item, index) => {
        const Icon = iconMap[index] || Design
        return (
          <div class="bg-[radial-gradient(50%_50%_at_50%_50%,#485760_0%,#1D2F3A_100%)] border border-[#5D5D5D] py-6 px-5 text-white text-center">
            <div class="size-18 mx-auto rounded-full flex items-center justify-center overflow-hidden bg-secondary border border-white p-4 img__contain img__h-full mb-4">
              {item.icon ? (
                <img src={item.icon} alt={item.title} />
              ) : (
                <Icon class="text-white w-full h-full" />
              )}
            </div>
            <p class="text-[1.25rem] font-bold uppercase">{item.title}</p>
            <div class="s-content">{item.content}</div>
          </div>
        )
      })
    }
  </div>
</section>
