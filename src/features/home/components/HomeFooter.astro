---
import footerLogo from "@/assets/astro.svg";
---

<footer class="bg-brand-950 text-white">
  <div class="container-home grid gap-8 py-12 xl:grid-cols-[1.2fr_repeat(3,1fr)]">
    <div>
      <div class="flex items-center gap-3 font-bold">
        <img src={footerLogo.src} alt="LuxiArc" class="h-[52px] w-[52px] object-contain" />
        <span class="uppercase">Cong ty LuxiArc</span>
      </div>
      <p class="mt-4 text-white/80">So 183 Cau Giay - Thanh Xuan - Ha Noi</p>
      <p class="mt-2 text-white/80">Hotline: 012346789</p>
    </div>
    <div>
      <h3 class="mb-4 text-lg font-semibold uppercase">Lien ket</h3>
      <a href="#" class="mb-2 block text-white/80">Quy trinh lam viec</a>
      <a href="#" class="mb-2 block text-white/80">Hinh thuc thanh toan</a>
      <a href="#" class="mb-2 block text-white/80">Chinh sach giao hang</a>
    </div>
    <div>
      <h3 class="mb-4 text-lg font-semibold uppercase">Lien ket</h3>
      <a href="#" class="mb-2 block text-white/80">Chinh sach doi tra</a>
      <a href="#" class="mb-2 block text-white/80">Chinh sach bao hanh</a>
      <a href="#" class="mb-2 block text-white/80">Kiem tra bao hanh</a>
    </div>
    <div>
      <h3 class="mb-4 text-lg font-semibold uppercase">Lien ket</h3>
      <a href="#" class="mb-2 block text-white/80">Thiet ke</a>
      <a href="#" class="mb-2 block text-white/80">Thi cong</a>
      <a href="#" class="mb-2 block text-white/80">Lien he</a>
    </div>
  </div>
  <div class="border-t border-white/10 py-4 text-center text-sm text-white/75">Copyright © 2026 LuxiArc. All Rights Reserved.</div>
</footer>
