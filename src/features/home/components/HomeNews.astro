---
// HomeNews.astro - Tin tức mới nhất
import { NewsCard, getNewsItems } from "@/features/news"
import { CLink } from "@/components/ui"
import { ROUTES } from "@/utils/routes"

const newsItems = await getNewsItems({ per_page: 3 })
---

{
  newsItems.length > 0 && (
    <section class="py-8 container overflow-hidden">
      <div class="flex justify-between items-center mb-8" data-aos="fade-up">
        <h2 class="title-head tracking-wider">Tin tức mới nhất</h2>

        <CLink
          href={ROUTES.NEWS.INDEX}
          class="flex items-center py-3 px-4 border border-[#3F3F3F] hover:bg-secondary hover:border-secondary text-[#3F3F3F] hover:text-white"
        >
          Xem tất cả
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 18 18"
            fill="none"
            class="ml-2"
          >
            <path
              d="M7.5 12.75L11.25 9L7.5 5.25"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </CLink>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {newsItems.map((item, index) => (
          <div data-aos="fade-up" data-aos-delay={index * 100}>
            <NewsCard item={item} />
          </div>
        ))}
      </div>
    </section>
  )
}
