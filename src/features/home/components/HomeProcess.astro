---
// HomeProcess.astro - Quy trình của chúng tôi
const steps = [
  {
    number: "1",
    title: "TƯ VẤN & KHẢO SÁT",
    description: "Tiếp nhận yêu cầu và khảo sát thực địa mặt bằng.",
  },
  {
    number: "2",
    title: "THIẾT KẾ Ý TƯỞNG",
    description: "Lên phương án kiến trúc 2D/3D phù hợp với ngân sách.",
  },
  {
    number: "3",
    title: "HỢP ĐỒNG & CẤP PHÉP",
    description: "Hoàn thiện hồ sơ pháp lý và ký kết hợp đồng rõ ràng.",
  },
  {
    number: "4",
    title: "THI CÔNG XÂY DỰNG",
    description: "Triển khai thi công đúng tiến độ và tiêu chuẩn kỹ thuật.",
  },
  {
    number: "5",
    title: "GIÁM SÁT CHẤT LƯỢNG",
    description: "Kiểm soát chặt chẽ từng hạng mục bởi đội ngũ kỹ sư.",
  },
  {
    number: "6",
    title: "BÀN GIAO & BẢO HÀNH",
    description: "Nghiệm thu công trình và cam kết bảo trì định kỳ.",
  },
]
---

<section class="py-16 bg-[#FAFAFA]">
  {/* Định nghĩa gradient chung cho các số quy trình */}
  <svg class="absolute w-0 h-0 overflow-hidden" aria-hidden="true">
    <defs>
      <linearGradient id="gold-border" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#DFC976" stop-opacity="1"></stop>
        <stop offset="25%" stop-color="#A37A48" stop-opacity="1"></stop>
        <stop offset="50%" stop-color="#DFC976" stop-opacity="0.20"></stop>
        <stop offset="65%" stop-color="#A37A48" stop-opacity="0.10"></stop>
        <stop offset="100%" stop-color="#DFC976" stop-opacity="0"></stop>
      </linearGradient>
    </defs>
  </svg>

  <div class="container">
    <h2 class="title-head mb-8 text-center">Quy trình của chúng tôi</h2>

    <div class="flex flex-wrap justify-between gap-y-6 -mx-3">
      {
        steps.map((step, index) => (
          <div class="w-full sm:w-1/2 lg:w-1/3 2xl:w-[30%] px-3">
            <div class="pl-4">
              <svg
                viewBox="0 0 80 96"
                class="h-24 w-auto -translate-x-4 -mb-8 select-none pointer-events-none overflow-visible"
                aria-hidden="true"
              >
                <text
                  x="2"
                  y="80"
                  font-family="Oswald"
                  font-size="96"
                  font-weight="600"
                  fill="none"
                  stroke="url(#gold-border)"
                  stroke-width="2"
                >
                  {index + 1}
                </text>
              </svg>
              <p class="text-primary text-[1.25rem] font-semibold mb-3 relative z-1">
                {step.title}
              </p>
              <div class="s-content">{step.description}</div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
