---
import cardImg from "@/assets/background.svg";
import facebookIcon from "@/assets/astro.svg";
import youtubeIcon from "@/assets/background.svg";
---

<section>
  <section class="container-home py-20">
    <div class="mb-8 text-center">
      <p class="text-[14px] font-semibold tracking-[0.16em] text-text-500">GIAI PHAP XAY DUNG TOAN DIEN</p>
      <h2 class="mt-3 text-3xl font-semibold uppercase">Ba mang dich vu chinh</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      <article class="relative min-h-[250px] overflow-hidden text-white"><img src={cardImg.src} alt="" class="absolute inset-0 h-full w-full object-cover" /><div class="absolute inset-0 bg-gradient-to-b from-brand-950/10 to-brand-950/80"></div><div class="absolute inset-x-0 bottom-0 p-5"><h3 class="text-xl font-semibold">Thiet ke & Thi cong</h3><p class="mt-2 text-sm leading-7 text-white/90">Giai phap dong bo tu tu van, thiet ke den thi cong hoan thien.</p></div></article>
      <article class="relative min-h-[250px] overflow-hidden text-white"><img src={cardImg.src} alt="" class="absolute inset-0 h-full w-full object-cover" /><div class="absolute inset-0 bg-gradient-to-b from-brand-950/10 to-brand-950/80"></div><div class="absolute inset-x-0 bottom-0 p-5"><h3 class="text-xl font-semibold">Noi that cao cap</h3><p class="mt-2 text-sm leading-7 text-white/90">Tap trung vat lieu, anh sang va ty le khong gian.</p></div></article>
      <article class="relative min-h-[250px] overflow-hidden text-white"><img src={cardImg.src} alt="" class="absolute inset-0 h-full w-full object-cover" /><div class="absolute inset-0 bg-gradient-to-b from-brand-950/10 to-brand-950/80"></div><div class="absolute inset-x-0 bottom-0 p-5"><h3 class="text-xl font-semibold">Hau mai chuyen nghiep</h3><p class="mt-2 text-sm leading-7 text-white/90">Bao hanh va ho tro ky thuat ngay tai cong trinh.</p></div></article>
    </div>
  </section>

  <section class="container-home py-20">
    <div class="mb-8 text-center">
      <p class="text-[14px] font-semibold tracking-[0.16em] text-text-500">QUY TRINH CUA CHUNG TOI</p>
      <h2 class="mt-3 text-3xl font-semibold uppercase">6 buoc ro rang, minh bach</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-6">
      <article class="border border-surface-200 p-5"><span class="text-[28px] font-bold text-accent-500">01</span><h3 class="mt-4 text-lg font-semibold">Tu van & khao sat</h3><p class="mt-2 text-sm leading-7 text-text-700">Lorem ipsum dolor sit amet consectetur. Vitae neque pretium nisl.</p></article>
      <article class="border border-surface-200 p-5"><span class="text-[28px] font-bold text-accent-500">02</span><h3 class="mt-4 text-lg font-semibold">Thiet ke y tuong</h3><p class="mt-2 text-sm leading-7 text-text-700">Lorem ipsum dolor sit amet consectetur. Vitae neque pretium nisl.</p></article>
      <article class="border border-surface-200 p-5"><span class="text-[28px] font-bold text-accent-500">03</span><h3 class="mt-4 text-lg font-semibold">Bao gia & chot phuong an</h3><p class="mt-2 text-sm leading-7 text-text-700">Lorem ipsum dolor sit amet consectetur. Vitae neque pretium nisl.</p></article>
      <article class="border border-surface-200 p-5"><span class="text-[28px] font-bold text-accent-500">04</span><h3 class="mt-4 text-lg font-semibold">Thi cong xay dung</h3><p class="mt-2 text-sm leading-7 text-text-700">Lorem ipsum dolor sit amet consectetur. Vitae neque pretium nisl.</p></article>
      <article class="border border-surface-200 p-5"><span class="text-[28px] font-bold text-accent-500">05</span><h3 class="mt-4 text-lg font-semibold">Giam sat chat luong</h3><p class="mt-2 text-sm leading-7 text-text-700">Lorem ipsum dolor sit amet consectetur. Vitae neque pretium nisl.</p></article>
      <article class="border border-surface-200 p-5"><span class="text-[28px] font-bold text-accent-500">06</span><h3 class="mt-4 text-lg font-semibold">Ban giao & bao hanh</h3><p class="mt-2 text-sm leading-7 text-text-700">Lorem ipsum dolor sit amet consectetur. Vitae neque pretium nisl.</p></article>
    </div>
  </section>

  <section class="bg-brand-900 py-20 text-white">
    <div class="container-home">
      <div class="mb-8 text-center">
        <p class="text-[14px] font-semibold tracking-[0.16em] text-white/80">TAI SAO CHON CHUNG TOI?</p>
        <h2 class="mt-3 text-3xl font-semibold uppercase">4 ly do ban nen lua chon LuxiArc</h2>
      </div>
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        <article class="border border-white/10 bg-white/5 p-6 text-center"><h3 class="text-xl font-semibold">Vat lieu tot</h3><p class="mt-3 leading-7 text-white/80">Chon loc theo tieu chuan du an thuc te.</p></article>
        <article class="border border-white/10 bg-white/5 p-6 text-center"><h3 class="text-xl font-semibold">Doi ngu</h3><p class="mt-3 leading-7 text-white/80">Kien truc su, giam sat va tho thi cong.</p></article>
        <article class="border border-white/10 bg-white/5 p-6 text-center"><h3 class="text-xl font-semibold">Minh bach</h3><p class="mt-3 leading-7 text-white/80">Bao gia ro rang, han che phat sinh.</p></article>
        <article class="border border-white/10 bg-white/5 p-6 text-center"><h3 class="text-xl font-semibold">Dung tien do</h3><p class="mt-3 leading-7 text-white/80">Ke hoach ro rang va theo doi lien tuc.</p></article>
      </div>
    </div>
  </section>

  <section class="container-home py-20">
    <div class="mb-8 flex items-center justify-between gap-4">
      <h2 class="text-3xl font-semibold uppercase">Tin tuc moi nhat</h2>
