---
import Layout from "@/layouts/Layout.astro"
import { ItemV2, PageBanner, PageContent } from "@/components/ui"
import { getServicesPageDetails, getServicesItems } from "@/features/services"
import { getLinkByResource } from "@/utils/routes"
import { PAGE_SLUGS } from "@/constants/pageSlugs"

const pageDetails = await getServicesPageDetails(PAGE_SLUGS.SERVICES)

if (!pageDetails) {
  return Astro.redirect("/404")
}

const items = await getServicesItems(PAGE_SLUGS.SERVICES)

const seoTitle = pageDetails.seo?.title || pageDetails.name || ""
const seoDesc = pageDetails.seo?.description || pageDetails.name || ""
---

<Layout title={seoTitle} description={seoDesc}>
  <!-- Banner -->
  <PageBanner title={pageDetails.name} image={pageDetails?.banner || ""} />

  <PageContent content={pageDetails?.extras.intro_content} />

  <!-- Items list Section -->
  {
    items && items.length > 0 && (
      <section class="container my-12">
        <div class="bg-[#FAFAFA] p-4 lg:px-8 md:p-6 space-y-6">
          {items.map((item) => (
            <ItemV2
              title={item.name}
              image={item.img}
              description={item.short_content || ""}
              href={getLinkByResource(item.resource_type, item.slug)}
            />
          ))}
        </div>
      </section>
    )
  }
</Layout>
