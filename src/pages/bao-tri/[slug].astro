---
import Layout from "@/layouts/Layout.astro"
import { Breadcrumbs, ItemSlider, PageDetailContent } from "@/components/ui"
import {
  getMaintenanceItems,
  getMaintenanceItemDetail,
} from "@/features/maintenance"
import { ROUTES } from "@/utils/routes"
import { PAGE_SLUGS } from "@/constants/pageSlugs"
import type { GetStaticPaths } from "astro"

export const getStaticPaths = (async () => {
  const items = await getMaintenanceItems(PAGE_SLUGS.MAINTENANCE)
  const paths = await Promise.all(
    items.map(async (item) => {
      const detail = await getMaintenanceItemDetail(item.slug)
      return {
        params: { slug: item.slug },
        props: { item: detail || item, allItems: items },
      }
    })
  )
  return paths
}) satisfies GetStaticPaths

const { item, allItems } = Astro.props

const seoTitle = item.seo.title || `${item.name} | LuxiArc`
const seoDesc = item.seo.description || item.short_content || ""
---

<Layout title={seoTitle} description={seoDesc}>
  <Breadcrumbs
    items={[
      { name: "Bảo trì & sửa chữa", url: ROUTES.MAINTENANCE.INDEX },
      { name: item.name },
    ]}
  />

  <ItemSlider items={allItems} basePath={ROUTES.MAINTENANCE.INDEX} />

  <PageDetailContent title={item.name} content={item.content} />
</Layout>
