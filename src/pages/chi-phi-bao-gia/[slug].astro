---
import Layout from "@/layouts/Layout.astro"
import { Breadcrumbs, ItemSlider, PageDetailContent } from "@/components/ui"
import { getCostsItems, getCostsItemDetail } from "@/features/costs"
import { ROUTES } from "@/utils/routes"
import { PAGE_SLUGS } from "@/constants/pageSlugs"
import type { GetStaticPaths } from "astro"

export const getStaticPaths = (async () => {
  const items = await getCostsItems(PAGE_SLUGS.COSTS)
  const paths = await Promise.all(
    items.map(async (item) => {
      const detail = await getCostsItemDetail(item.slug)
      return {
        params: { slug: item.slug },
        props: { item: detail || item, allItems: items },
      }
    })
  )
  return paths
}) satisfies GetStaticPaths

const { item, allItems } = Astro.props

const seoTitle = item.seo?.title || `${item.name} | LuxiArc`
const seoDesc = item.seo?.description || item.short_content || ""
---

<Layout title={seoTitle} description={seoDesc}>
  <Breadcrumbs
    items={[{ name: "Báo giá", url: ROUTES.COSTS.INDEX }, { name: item.name }]}
  />

  <ItemSlider items={allItems} basePath={ROUTES.COSTS.INDEX} />

  <PageDetailContent title={item.name} content={item.content} />
</Layout>
